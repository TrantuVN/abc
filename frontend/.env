# Vite Environment Variables

# API backend URL
# Changed from REACT_APP_API_BASE_URL to VITE_API_BASE_URL
VITE_API_BASE_URL=http://localhost:3000

# Smart Contract Addresses
# Changed from REACT_APP_CONTENT_MANAGER_ADDRESS to VITE_CONTENT_MANAGER_ADDRESS
VITE_CONTENT_MANAGER_ADDRESS=your_deployed_contract_address
# Changed from REACT_APP_BANDWIDTH_MARKET_ADDRESS to VITE_BANDWIDTH_MARKET_ADDRESS
VITE_BANDWIDTH_MARKET_ADDRESS=your_deployed_contract_address
# Changed from REACT_APP_SCOIN_TOKEN_ADDRESS to VITE_SCOIN_TOKEN_ADDRESS
VITE_SCOIN_TOKEN_ADDRESS=your_deployed_contract_address
VITE_IPFS_GATEWAY=http://localhost:8080
# IPFS Gateway
# Changed from REACT_APP_IPFS_GATEWAY to VITE_IPFS_GATEWAY
VITE_IPFS_GATEWAY=http://localhost:5001
Blockchain Network Info
# Changed from REACT_APP_NETWORK_RPC_URL to VITE_NETWORK_RPC_URL
VITE_NETWORK_RPC_URL=your_network_rpc_url
# Changed from REACT_APP_CHAIN_ID to VITE_CHAIN_ID
VITE_CHAIN_ID=1
VITE_HIVE_API_KEY=AMQ2lMavsbkBTLIaHjMVElIcoFlX6Haf
VITE_CHAIN_ID=1337
